<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Facilities Links</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface-2: #22263a;
      --border: rgba(255,255,255,0.08);
      --text: #e8eaf0;
      --text-muted: #7c8099;
      --accent: #4f6ef7;
      --accent-glow: rgba(79,110,247,0.25);

      --alc:     #00875a;
      --alc-dim: rgba(0,135,90,0.15);
      --niagara: #c0392b;
      --niagara-dim: rgba(192,57,43,0.15);
      --summer:  #d4830a;
      --summer-dim: rgba(212,131,10,0.15);
      --ready:   #1a6fbf;
      --ready-dim: rgba(26,111,191,0.15);
      --workday: #e05c00;
      --workday-dim: rgba(224,92,0,0.15);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }

    /* Background grid */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(79,110,247,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(79,110,247,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    /* Glow blob */
    body::after {
      content: '';
      position: fixed;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(79,110,247,0.08) 0%, transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 36px 40px;
      width: 100%;
      max-width: 460px;
      position: relative;
      z-index: 1;
      box-shadow: 0 24px 60px rgba(0,0,0,0.5);
      animation: fadeUp 0.4s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .header {
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .header-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 4px;
    }

    .logo-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .header h1 {
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-muted);
      font-family: 'DM Mono', monospace;
    }

    .header p {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 2px;
      padding-left: 18px;
    }

    .links {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .link-btn {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface-2);
      cursor: pointer;
      text-decoration: none;
      color: var(--text);
      transition: all 0.18s ease;
      position: relative;
      overflow: hidden;
      animation: fadeUp 0.4s ease both;
    }

    .link-btn:nth-child(1) { animation-delay: 0.05s; }
    .link-btn:nth-child(2) { animation-delay: 0.10s; }
    .link-btn:nth-child(3) { animation-delay: 0.15s; }
    .link-btn:nth-child(4) { animation-delay: 0.20s; }
    .link-btn:nth-child(5) { animation-delay: 0.25s; }

    .link-btn::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      border-radius: 3px 0 0 3px;
      background: var(--accent);
      opacity: 0;
      transition: opacity 0.18s ease;
    }

    .link-btn:hover {
      border-color: rgba(255,255,255,0.15);
      transform: translateX(3px);
      background: #262a3d;
    }

    .link-btn:hover::before { opacity: 1; }

    .link-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    .link-info { flex: 1; }

    .link-name {
      font-size: 14px;
      font-weight: 600;
      line-height: 1.2;
    }

    .link-desc {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 2px;
    }

    .link-arrow {
      font-size: 16px;
      color: var(--text-muted);
      transition: transform 0.18s ease, color 0.18s ease;
    }

    .link-btn:hover .link-arrow {
      transform: translateX(3px);
      color: var(--text);
    }

    /* Color theming per link */
    .btn-alc     .link-icon { background: var(--alc-dim);     color: var(--alc); }
    .btn-niagara .link-icon { background: var(--niagara-dim); color: var(--niagara); }
    .btn-summer  .link-icon { background: var(--summer-dim);  color: var(--summer); }
    .btn-ready   .link-icon { background: var(--ready-dim);   color: var(--ready); }
    .btn-workday .link-icon { background: var(--workday-dim); color: var(--workday); }

    .btn-alc:hover     { border-color: var(--alc);     box-shadow: 0 0 0 1px var(--alc-dim); }
    .btn-niagara:hover { border-color: var(--niagara); box-shadow: 0 0 0 1px var(--niagara-dim); }
    .btn-summer:hover  { border-color: var(--summer);  box-shadow: 0 0 0 1px var(--summer-dim); }
    .btn-ready:hover   { border-color: var(--ready);   box-shadow: 0 0 0 1px var(--ready-dim); }
    .btn-workday:hover { border-color: var(--workday); box-shadow: 0 0 0 1px var(--workday-dim); }

    .btn-alc::before     { background: var(--alc); }
    .btn-niagara::before { background: var(--niagara); }
    .btn-summer::before  { background: var(--summer); }
    .btn-ready::before   { background: var(--ready); }
    .btn-workday::before { background: var(--workday); }

    /* ── Modal overlay ── */
    .modal {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(6px);
      align-items: center;
      justify-content: center;
      animation: fadeIn 0.2s ease;
    }
    .modal.active { display: flex; }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    .modal-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px 36px;
      width: 90%;
      max-width: 400px;
      text-align: center;
      box-shadow: 0 32px 80px rgba(0,0,0,0.6);
      animation: popIn 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
    }

    @keyframes popIn {
      from { opacity: 0; transform: scale(0.9); }
      to   { opacity: 1; transform: scale(1); }
    }

    .modal-icon {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      margin: 0 auto 16px;
    }

    .modal-box h2 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .modal-box p {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 24px;
      line-height: 1.5;
    }

    .modal-url {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 10px;
      color: var(--text-muted);
      margin-bottom: 20px;
      word-break: break-all;
      display: block;
    }

    .modal-actions {
      display: flex;
      gap: 10px;
      justify-content: center;
    }

    .btn-open {
      padding: 10px 22px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      color: #fff;
      transition: opacity 0.15s, transform 0.15s;
      font-family: 'DM Sans', sans-serif;
    }

    .btn-open:hover { opacity: 0.85; transform: translateY(-1px); }
    .btn-open:active { transform: translateY(0); }

    .btn-cancel {
      padding: 10px 18px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
      font-family: 'DM Sans', sans-serif;
    }

    .btn-cancel:hover { background: var(--surface-2); color: var(--text); }

    .footer {
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 11px;
      color: var(--text-muted);
      font-family: 'DM Mono', monospace;
      letter-spacing: 0.03em;
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="header">
      <div class="header-top">
        <div class="logo-dot"></div>
        <h1>Facilities Portal</h1>
      </div>
      <p>USF Facilities Management — External Links</p>
    </div>

    <div class="links">
      <a class="link-btn btn-summer" onclick="openModal('summer')">
        <div class="link-icon">☀️</div>
        <div class="link-info">
          <div class="link-name">Summer Turnover</div>
          <div class="link-desc">inspect.facmgmt.io</div>
        </div>
        <span class="link-arrow">›</span>
      </a>

      <a class="link-btn btn-alc" onclick="openModal('alc')">
        <div class="link-icon">🚀</div>
        <div class="link-info">
          <div class="link-name">Automated Logic (ALC)</div>
          <div class="link-desc">vmi-facilities-01.ds.usfca.edu</div>
        </div>
        <span class="link-arrow">›</span>
      </a>

      <a class="link-btn btn-niagara" onclick="openModal('niagara')">
        <div class="link-icon">🌐</div>
        <div class="link-info">
          <div class="link-name">Niagara Controls</div>
          <div class="link-desc">10.21.0.2</div>
        </div>
        <span class="link-arrow">›</span>
      </a>

      <a class="link-btn btn-ready" onclick="openModal('ready')">
        <div class="link-icon">📋</div>
        <div class="link-info">
          <div class="link-name">Ready Request</div>
          <div class="link-desc">usfreadyprod.assetworks.cloud</div>
        </div>
        <span class="link-arrow">›</span>
      </a>

      <a class="link-btn btn-workday" onclick="openModal('workday')">
        <div class="link-icon">💼</div>
        <div class="link-info">
          <div class="link-name">Workday</div>
          <div class="link-desc">wd5.myworkday.com</div>
        </div>
        <span class="link-arrow">›</span>
      </a>
    </div>

    <div class="footer">USF Facilities Management · AiM WorkDesk</div>
  </div>

  <!-- Modal -->
  <div class="modal" id="modal">
    <div class="modal-box">
      <div class="modal-icon" id="modal-icon"></div>
      <h2 id="modal-title"></h2>
      <p id="modal-desc"></p>
      <span class="modal-url" id="modal-url"></span>
      <div class="modal-actions">
        <button class="btn-open" id="modal-open-btn" onclick="launchSite()">Open in New Window</button>
        <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    const sites = {
      summer: {
        name: 'Summer Turnover',
        desc: 'Opens the Facilities Management inspection portal.',
        url: 'https://inspect.facmgmt.io',
        icon: '☀️',
        color: '#d4830a'
      },
      alc: {
        name: 'Automated Logic (ALC)',
        desc: 'Opens the ALC building automation system.',
        url: 'http://vmi-facilities-01.ds.usfca.edu/',
        icon: '🚀',
        color: '#00875a'
      },
      niagara: {
        name: 'Niagara Controls',
        desc: 'Opens the Niagara building controls interface.',
        url: 'http://10.21.0.2',
        icon: '🌐',
        color: '#c0392b'
      },
      ready: {
        name: 'Ready Request',
        desc: 'Opens the AssetWorks Ready service request system.',
        url: 'https://usfreadyprod.assetworks.cloud/ready/',
        icon: '📋',
        color: '#1a6fbf'
      },
      workday: {
        name: 'Workday',
        desc: 'Opens the USF Workday HR and finance portal.',
        url: 'https://wd5.myworkday.com/usfca/d/home.htmld',
        icon: '💼',
        color: '#e05c00'
      }
    };

    let currentSite = null;

    function openModal(key) {
      currentSite = sites[key];
      const modal = document.getElementById('modal');
      document.getElementById('modal-icon').textContent = currentSite.icon;
      document.getElementById('modal-icon').style.background = currentSite.color + '22';
      document.getElementById('modal-title').textContent = currentSite.name;
      document.getElementById('modal-desc').textContent = currentSite.desc;
      document.getElementById('modal-url').textContent = currentSite.url;
      document.getElementById('modal-open-btn').style.background = currentSite.color;
      modal.classList.add('active');
    }

    function closeModal() {
      document.getElementById('modal').classList.remove('active');
      currentSite = null;
    }

    function launchSite() {
      if (!currentSite) return;
      const w = 1200, h = 800;
      const left = Math.round((screen.width  - w) / 2);
      const top  = Math.round((screen.height - h) / 2);
      window.open(
        currentSite.url,
        '_blank',
        `width=${w},height=${h},top=${top},left=${left},resizable=yes,scrollbars=yes,toolbar=no,menubar=no,location=yes`
      );
      closeModal();
    }

    // Close modal on backdrop click
    document.getElementById('modal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });

    // Close modal on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });

    // Auto-launch if ?site= param is present (for direct AiM linking)
    (function() {
      const params = new URLSearchParams(window.location.search);
      const site = params.get('site');
      if (site && sites[site]) openModal(site);
    })();
  </script>
</body>
</html>
