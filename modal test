Pros: Simple, works everywhere, no iframe needed.
Cons: Popup blockers may intercept it if not triggered directly from a click. The window is technically separate from your page.

Option 2: Modal with a redirect message + button
If the target sites have X-Frame-Options or CSP headers blocking embedding anyway (very common for internal systems), you can show a modal that informs the user and provides a clearly styled "Open" button — keeping your UI consistent while opening in a new tab.

Here's a full rewrite using Option 1 as primary with a clean fallback notice:
html<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Facilities Redirects</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: #f0f0f0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }

    a.button {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: bold;
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      margin: 10px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.2);
      width: 200px;
      height: 40px;
      cursor: pointer;
      border: none;
    }

    .automated-logic { background-color: #006747; }
    .automated-logic:hover { background-color: #004d36; }
    .niagara { background-color: #990000; }
    .niagara:hover { background-color: #660000; }

    /* Modal overlay */
    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0; top: 0;
      width: 100%; height: 100%;
      background-color: rgba(0,0,0,0.6);
      align-items: center;
      justify-content: center;
    }
    .modal.active { display: flex; }

    .modal-box {
      background: #fff;
      border-radius: 10px;
      padding: 30px 40px;
      text-align: center;
      box-shadow: 0 5px 20px rgba(0,0,0,0.4);
      max-width: 400px;
      width: 90%;
    }
    .modal-box h2 { margin-top: 0; }
    .modal-box p { color: #555; font-size: 14px; }

    .open-btn {
      display: inline-block;
      margin-top: 10px;
      padding: 10px 24px;
      font-size: 14px;
      font-weight: bold;
      color: #fff;
      border-radius: 6px;
      text-decoration: none;
      cursor: pointer;
      border: none;
    }
    .cancel-btn {
      display: inline-block;
      margin-top: 10px;
      margin-left: 10px;
      padding: 10px 18px;
      font-size: 14px;
      color: #333;
      background: #e0e0e0;
      border-radius: 6px;
      cursor: pointer;
      border: none;
    }
    .cancel-btn:hover { background: #ccc; }
  </style>
</head>
<body>

  <a class="button automated-logic" id="openALC">🚀 Launch ALC</a>
  <a class="button niagara" id="openNiagara">🌐 Launch Niagara</a>

  <!-- ALC Confirm Modal -->
  <div class="modal" id="modalALC">
    <div class="modal-box">
      <h2>🚀 Automated Logic</h2>
      <p>This will open the ALC system in a new popup window.</p>
      <button class="open-btn automated-logic" id="confirmALC">Open ALC</button>
      <button class="cancel-btn" id="cancelALC">Cancel</button>
    </div>
  </div>

  <!-- Niagara Confirm Modal -->
  <div class="modal" id="modalNiagara">
    <div class="modal-box">
      <h2>🌐 Niagara</h2>
      <p>This will open the Niagara system in a new popup window.</p>
      <button class="open-btn niagara" id="confirmNiagara">Open Niagara</button>
      <button class="cancel-btn" id="cancelNiagara">Cancel</button>
    </div>
  </div>

  <script>
    function openPopup(url) {
      const w = 1100, h = 750;
      const left = (screen.width - w) / 2;
      const top = (screen.height - h) / 2;
      window.open(url, '_blank',
        `width=${w},height=${h},top=${top},left=${left},resizable=yes,scrollbars=yes,toolbar=no,menubar=no`
      );
    }

    function setupModal(openId, modalId, cancelId, confirmId, url) {
      const modal = document.getElementById(modalId);
      document.getElementById(openId).onclick = () => modal.classList.add('active');
      document.getElementById(cancelId).onclick = () => modal.classList.remove('active');
      document.getElementById(confirmId).onclick = () => {
        openPopup(url);
        modal.classList.remove('active');
      };
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.remove('active');
      });
    }

    setupModal('openALC',     'modalALC',     'cancelALC',     'confirmALC',     'http://vmi-facilities-01.ds.usfca.edu/');
    setupModal('openNiagara', 'modalNiagara', 'cancelNiagara', 'confirmNiagara', 'http://10.21.0.2');
  </script>

</body>
</html>
